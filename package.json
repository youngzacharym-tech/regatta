{
  "name": "regatta-game",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "random": "tsx play-random-game.ts",
    "batch": "tsx batch-random-games.ts",
    "referee": "tsx referee.ts",
    "start": "tsx referee.ts",
    "build:stage": "cd stage && npm install && npm run build",
    "build:api": "esbuild api/room.ts --bundle --platform=node --format=esm --target=node20 --external:ioredis --outfile=api/room.js",
    "build": "npm run build:stage",
    "deploy": "npm run build:api && npx vercel deploy --prod",
    "test-engine": "tsx test-engine-drive.ts"
  },
  "dependencies": {
    "ioredis": "^5.11.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1"
  }
}